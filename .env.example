# ─── Spotify API ─────────────────────────────────────────────────────────────
# Obtenelas en: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# ─── AWS ─────────────────────────────────────────────────────────────────────
# Configurar con: aws configure
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key_aqui
AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui

# ─── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=spotify-sentiment-reports

# ─── API Gateway (completar después del deploy) ───────────────────────────────
# API_GATEWAY_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
